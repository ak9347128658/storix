{
  "name": "storebridge",
  "version": "1.0.4",
  "description": "A unified, production-ready cloud storage abstraction library for Node.js and TypeScript",
  "keywords": [
    "storage",
    "s3",
    "gcs",
    "azure",
    "cloudflare",
    "r2",
    "minio",
    "supabase",
    "firebase",
    "appwrite",
    "backblaze",
    "digitalocean",
    "spaces",
    "cloud",
    "upload",
    "typescript"
  ],
  "author": "Asif Khan <ak2311581@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ak9347128658/storix.git"
  },
  "bugs": {
    "url": "https://github.com/ak9347128658/storix/issues"
  },
  "homepage": "https://github.com/ak9347128658/storix#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./providers/s3": {
      "import": "./dist/providers/s3/index.js",
      "require": "./dist/providers/s3/index.cjs"
    },
    "./providers/r2": {
      "import": "./dist/providers/r2/index.js",
      "require": "./dist/providers/r2/index.cjs"
    },
    "./providers/gcs": {
      "import": "./dist/providers/gcs/index.js",
      "require": "./dist/providers/gcs/index.cjs"
    },
    "./providers/azure": {
      "import": "./dist/providers/azure/index.js",
      "require": "./dist/providers/azure/index.cjs"
    },
    "./providers/spaces": {
      "import": "./dist/providers/spaces/index.js",
      "require": "./dist/providers/spaces/index.cjs"
    },
    "./providers/b2": {
      "import": "./dist/providers/b2/index.js",
      "require": "./dist/providers/b2/index.cjs"
    },
    "./providers/minio": {
      "import": "./dist/providers/minio/index.js",
      "require": "./dist/providers/minio/index.cjs"
    },
    "./providers/supabase": {
      "import": "./dist/providers/supabase/index.js",
      "require": "./dist/providers/supabase/index.cjs"
    },
    "./providers/firebase": {
      "import": "./dist/providers/firebase/index.js",
      "require": "./dist/providers/firebase/index.cjs"
    },
    "./providers/appwrite": {
      "import": "./dist/providers/appwrite/index.js",
      "require": "./dist/providers/appwrite/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test",
    "release": "semantic-release",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": ">=3.0.0",
    "@aws-sdk/lib-storage": ">=3.0.0",
    "@aws-sdk/s3-request-presigner": ">=3.0.0",
    "@azure/storage-blob": ">=12.0.0",
    "@google-cloud/storage": ">=7.0.0",
    "@supabase/supabase-js": ">=2.0.0",
    "firebase-admin": ">=11.0.0",
    "minio": ">=8.0.0",
    "node-appwrite": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@aws-sdk/s3-request-presigner": {
      "optional": true
    },
    "@aws-sdk/lib-storage": {
      "optional": true
    },
    "@google-cloud/storage": {
      "optional": true
    },
    "@azure/storage-blob": {
      "optional": true
    },
    "@supabase/supabase-js": {
      "optional": true
    },
    "firebase-admin": {
      "optional": true
    },
    "node-appwrite": {
      "optional": true
    },
    "minio": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@azure/storage-blob": "^12.27.0",
    "@google-cloud/storage": "^7.14.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@supabase/supabase-js": "^2.47.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "firebase-admin": "^12.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "minio": "^8.0.2",
    "node-appwrite": "^14.0.0",
    "prettier": "^3.4.2",
    "semantic-release": "^24.2.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
